# ORIN Frontend Next.js Configuration
# Rename this file to .env or .env.local

# App URLs
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# API endpoint URLs (proxied via /api)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_AUTH_URL=http://localhost:3000/api/auth
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Better Auth Metrics Telemetry (optional)
NEXT_PUBLIC_BETTER_AUTH_API_KEY=

# Google OAuth (public client id)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
