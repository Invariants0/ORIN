# ───────── PRIMARY CONFIG ─────────
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ───────── AUTH (Optional / Derived) ─────────
# These variables should only be needed if you want to override the default derivation
# Based on FRONTEND_URL/api/auth and BACKEND_URL/ws

# Better Auth Metrics Telemetry (Backend Key)
NEXT_PUBLIC_BETTER_AUTH_API_KEY=

# ───────── SOCIAL AUTH (Required for UI feedback) ─────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
