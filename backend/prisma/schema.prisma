generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  auth0Id     String?  @unique
  name        String?
  avatar      String?
  notionToken String?
  geminiKey   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  summary   String?
  mode      String   @default("explore") // explore | build
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([createdAt])
  @@map("sessions")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String // user | assistant
  content   String   @db.Text
  intent    Stri  content   String  
  intent    String? // STORE | QUERY | GENERATE_DOC | OPERATE | UNCLEAR
  metadata  Json? // Additional metadata (processing time, confidence, etc.)
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("messages")
}

model Task {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  goal        String  
  title       String
  description String  
  status      String   @default("pending") // pending | in_progress | done | cancelled
  priority    String   @default("medium") // high | medium | low
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics TaskMetrics?

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("tasks")
}

model TaskMetrics {
  id            String   @id @default(cuid())
  taskId        String   @unique
  estimatedTime String?  // e.g., "2-3 hours", "30 minutes"
  actualTime    Int?     // in minutes
  success       Boolean  @default(true)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([success])
  @@index([createdAt])
  @@map("task_metrics")
}

model DecisionMetrics {
  id             String   @id @default(cuid())
  userId         String
  sessionId      String?
  input          String  
  strategy       String   // decompose | execute | resume | respond | ask
  confidence     Float
  reasoning      String  
  success        Boolean  @default(true)
  userFeedback   String? 
  contextFactors Json?    // Array of context factors
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([strategy])
  @@index([success])
  @@index([createdAt])
  @@map("decision_metrics")
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String
  goal        String  
  status      String   @default("pending") // pending | running | paused | completed | failed
  currentStep String?
  pauseReason String? 
  metadata    Json?    // Additional workflow metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  lockedBy    String?  // Worker ID that locked this workflow
  lockedAt    DateTime?

  steps   WorkflowStep[]
  results WorkflowResult[]

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([lockedBy])
  @@index([createdAt])
  @@map("workflows")
}

model WorkflowStep {
  id                String   @id @default(cuid())
  workflowId        String
  stepId            String   // Logical step ID (e.g., "step_1")
  name              String
  action            String
  parameters        Json
  dependencies      Json     // Array of step IDs
  riskLevel         String   // low | medium | high
  estimatedDuration Int      // milliseconds
  retryable         Boolean  @default(true)
  maxRetries        Int      @default(3)
  status            String   @default("pending") // pending | running | completed | failed | skipped
  attempts          Int      @default(0)
  error             String? 
  output            Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?
  timeoutAt         DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepId])
  @@index([workflowId])
  @@index([status])
  @@index([timeoutAt])
  @@map("workflow_steps")
}

model WorkflowResult {
  id         String   @id @default(cuid())
  workflowId String
  stepId     String
  output     Json
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([stepId])
  @@map("workflow_results")
}

model WorkflowQueue {
  id         String   @id @default(cuid())
  workflowId String
  stepId     String
  priority   Int      @default(0)
  retryCount Int      @default(0)
  scheduledAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([scheduledAt])
  @@index([priority])
  @@map("workflow_queue")
}

// Phase 19: Semi-Autonomous System Models

model AutonomyConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  level               String   @default("assisted") // manual | assisted | semi_auto | auto
  confidenceThreshold Int      @default(70)
  allowedActions      Json     // Array of allowed action types
  blockedActions      Json     // Array of blocked action types
  maxRetries          Int      @default(3)
  pauseThreshold      Float    @default(0.5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@map("autonomy_configs")
}

model Decision {
  id              String   @id @default(cuid())
  userId          String
  sessionId       String?
  workflowId      String?
  action          String   // Action type
  confidence      Int      // 0-100
  riskLevel       String   // low | medium | high | critical
  reasoning       String  
  dataUsed        Json     // Array of data sources
  expectedOutcome String  
  rollbackPlan    String  
  requiresApproval Boolean @default(false)
  createdAt       DateTime @default(now())

  executions ActionExecution[]

  @@index([userId])
  @@index([sessionId])
  @@index([workflowId])
  @@index([action])
  @@index([createdAt])
  @@map("decisions")
}

model ActionExecution {
  id         String    @id @default(cuid())
  decisionId String
  status     String    @default("pending") // pending | approved | rejected | executed | failed | undone
  executedAt DateTime?
  result     Json?
  error      String?  
  undoneAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([status])
  @@index([createdAt])
  @@map("action_executions")
}

model LearningData {
  id                String   @id @default(cuid())
  decisionId        String
  userId            String
  userApproved      Boolean
  actionSucceeded   Boolean
  userIntervened    Boolean
  performanceImpact Float    // -1.0 to 1.0
  metadata          Json?    // Additional learning metadata
  createdAt         DateTime @default(now())

  @@index([decisionId])
  @@index([userId])
  @@index([userApproved])
  @@index([actionSucceeded])
  @@index([createdAt])
  @@map("learning_data")
}

model Policy {
  id          String   @id @default(cuid())
  name        String
  description String  
