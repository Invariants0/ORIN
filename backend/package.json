{
  "name": "orin-backend",
  "version": "1.0.0",
  "description": "ORIN Context Operating System - Backend API",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed": "bun run src/scripts/seed.ts",
    "test:api": "bun run test-api-key.ts"
  },
  "keywords": ["orin", "notion", "ai", "context"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@better-auth/infra": "^0.1.13",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@notionhq/client": "^5.14.0",
    "@prisma/client": "6.19.2",
    "@types/node": "^25.5.0",
    "better-auth": "^1.5.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.9",
    "@types/ws": "^8.18.1",
    "prisma": "6.19.2",
    "typescript": "^5.7.2"
  }
