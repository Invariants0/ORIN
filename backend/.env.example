# ───────── SERVER CONFIG ─────────
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# ───────── DATABASE (SQLite for Local) ─────────
DATABASE_URL="file:./dev.db"

# ───────── BETTER AUTH (Required) ─────────
BETTER_AUTH_SECRET=             # Generate via openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:8000/api/auth
BETTER_AUTH_API_KEY=           # Optional, but recommended

# ───────── AI SERVICES (Required) ─────────
GEMINI_API_KEY=                # Get from AI Studio
GEMINI_MODEL=gemini-2.5-flash

# ───────── SOCIAL AUTH (Optional) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ───────── NOTION INTEGRATION ─────────
# Provider: 'mcp' or 'rest'
NOTION_PROVIDER=mcp
NOTION_API_KEY=               # Required for 'rest' provider
NOTION_DATABASE_ID=           # Optional
# For MCP
NOTION_MCP_URL=https://mcp.notion.com/mcp
NOTION_MCP_TOKEN=             # Your Notion Internal Integration Token (secret_*)
# Optional Manual OAuth Overrides
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# ───────── SECURITY (Optional) ─────────
# SESSION_SECRET=
# JWT_SECRET=
