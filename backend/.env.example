# Server Configuration
NODE_ENV=development
PORT=8000

# Database (SQLite for local development)
DATABASE_URL="file:./dev.db"

# Better Auth Configuration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000/api/auth
BETTER_AUTH_API_KEY=

# AI Services (Required for full functionality)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Notion Integration (Required for full functionality)
NOTION_PROVIDER=mcp
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_MCP_URL=https://mcp.notion.com/mcp
NOTION_MCP_TOKEN=
NOTION_MCP_PARENT_PAGE_ID=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8000/api/notion/oauth/callback
NOTION_OAUTH_AUTHORIZE_URL=https://api.notion.com/v1/oauth/authorize
NOTION_OAUTH_TOKEN_URL=https://api.notion.com/v1/oauth/token
NOTION_OAUTH_SUCCESS_REDIRECT=http://localhost:3000
NOTION_VERSION=2022-06-28

# Social OAuth (Managed via Better Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/callback/github

# Security
SESSION_SECRET=
JWT_SECRET=

# CORS
FRONTEND_URL=http://localhost:3000
