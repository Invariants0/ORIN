# PORT (Render sets this automatically, but good to have)
PORT=10000
NODE_ENV=production

# URLs
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com

# DATABASE
# Change to your production database URL (e.g., MongoDB Atlas or Render Postgres)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/orin?retryWrites=true&w=majority

# AUTH (Better Auth)
BETTER_AUTH_SECRET=generate_a_random_32_char_string
BETTER_AUTH_URL=https://your-backend.onrender.com/api/auth

# AI (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key

# NOTION (OAuth 2.0)
NOTION_OAUTH_CLIENT_ID=your_client_id
NOTION_OAUTH_CLIENT_SECRET=your_client_secret
NOTION_OAUTH_REDIRECT_URI=https://your-backend.onrender.com/api/notion/rest/callback

# NOTION MCP (Official Client)
NOTION_MCP_OAUTH_REDIRECT_URI=https://your-backend.onrender.com/api/notion/mcp/callback
NOTION_MCP_URL=https://mcp.notion.com/mcp
